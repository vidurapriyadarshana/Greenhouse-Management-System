						"body": {
							"mode": "raw",
							"raw": "{\n    \"deviceId\": \"{{device_id}}\",\n    \"zoneId\": \"{{zone_id}}\",\n    \"value\": {\n        \"temperature\": 45.0,\n        \"tempUnit\": \"CELSIUS\",\n        \"humidity\": 80.0,\n        \"humidityUnit\": \"PERCENT\"\n    },\n    \"capturedAt\": \"2026-03-10T12:00:00Z\"\n}"
						},
						"url": {
							"raw": "{{gateway_url}}/api/automation/process",
							"host": ["{{gateway_url}}"],
							"path": ["api", "automation", "process"]
						}
					}
				},
				{
					"name": "5. Get Automation Logs",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{gateway_url}}/api/automation/logs",
							"host": ["{{gateway_url}}"],
							"path": ["api", "automation", "logs"]
						}
					}
				},
				{
					"name": "6. Create Crop in Zone",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.id) {",
									"    pm.collectionVariables.set('crop_id', jsonData.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"E2E Tomatoes\",\n    \"zoneId\": \"{{zone_id}}\",\n    \"quantity\": 50\n}"
						},
						"url": {
							"raw": "{{gateway_url}}/api/crops",
							"host": ["{{gateway_url}}"],
							"path": ["api", "crops"]
						}
					}
				},
				{
					"name": "7. Crop → VEGETATIVE",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"VEGETATIVE\"\n}"
						},
						"url": {
							"raw": "{{gateway_url}}/api/crops/{{crop_id}}/status",
							"host": ["{{gateway_url}}"],
							"path": ["api", "crops", "{{crop_id}}", "status"]
						}
					}
				},
				{
					"name": "8. Crop → HARVESTED",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"HARVESTED\"\n}"
						},
						"url": {
							"raw": "{{gateway_url}}/api/crops/{{crop_id}}/status",
							"host": ["{{gateway_url}}"],
							"path": ["api", "crops", "{{crop_id}}", "status"]
						}
					}
				}
			]
		}
	]
}
