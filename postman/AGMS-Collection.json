		{
			"name": "Zone Service",
			"description": "Zone Management - CRUD operations for greenhouse zones with temperature/humidity thresholds",
			"item": [
				{
					"name": "Create Zone",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.id) {",
									"    pm.collectionVariables.set('zone_id', jsonData.data.id);",
									"    console.log('Zone ID saved: ' + jsonData.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Tropical Zone A\",\n    \"minTemp\": 20.0,\n    \"maxTemp\": 35.0,\n    \"minHumidity\": 60.0,\n    \"maxHumidity\": 90.0\n}"
						},
						"url": {
							"raw": "{{gateway_url}}/api/zones",
